      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "quantum_ci_quantum_ci_tvd",
          "legendFormat": "TVD — {{repo}}",
          "refId": "A"
        }
      ],
      "title": "Total Variation Distance (TVD) — Longitudinal",
      "type": "timeseries"
    },
